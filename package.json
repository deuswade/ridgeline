  "description": "Parse an EFT (NIST ITL) fingerprint file and lay the demographics and prints onto a printable FD-258 card.",
  "license": "GPL-3.0-or-later",
  "keywords": [
    "fd-258",
    "fingerprint",
    "eft",
    "nist-itl",
    "wsq",
    "pdf"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "make:template": "node scripts/make-placeholder-template.mjs",
    "make:fixture": "node scripts/make-fixture-eft.mjs"
  },
  "dependencies": {
    "@li0ard/wsq": "^0.1.1",
